{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codux",
  "version": "0.1.0",
  "identifier": "cn.dux.codux.tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codux",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        },
        "windowEffects": {
          "effects": ["sidebar", "mica", "acrylic"],
          "state": "active",
          "radius": 12,
          "color": "#171b223a"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/duxweb/codux/releases/download/tauri-stable/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxRTg4MkJBQzYxMENDOApSV1RJREdHc0s0Z2VBaWh3NFFLMDhIK3R3NUJVRFlyUUR3dzZHUkNWUUtXdEg2UnZPVmUvaHVhQQo="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [],
    "resources": {
      "./infoplist/": ""
    },
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
