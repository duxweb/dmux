    "settings.pet.speech.frequency_help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Frequency is estimated per hour, not a daily cap. The shortest global cooldown is 30 seconds."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Häufigkeit ist pro Stunde geschätzt, kein Tageslimit. Die kürzeste globale Abklingzeit beträgt 30 Sekunden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La frecuencia se estima por hora, no es un límite diario. El enfriamiento global mínimo es de 30 segundos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La fréquence est estimée par heure, ce n’est pas un plafond quotidien. Le délai global minimal est de 30 secondes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "頻度は1時間あたりの目安で、1日の上限ではありません。全体クールダウンの最短は30秒です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빈도는 일일 제한이 아니라 시간당 예상치입니다. 전체 쿨다운은 최소 30초입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A frequência é estimada por hora, não é um limite diário. O menor intervalo global é de 30 segundos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Частота оценивается за час, это не дневной лимит. Минимальная общая пауза — 30 секунд."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "频率按每小时估算，不是每日硬上限；所有对话最短全局冷却不低于 30 秒。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "頻率按每小時估算，不是每日硬上限；所有對話最短全域冷卻不低於 30 秒。"
          }
        }
      }
    },
