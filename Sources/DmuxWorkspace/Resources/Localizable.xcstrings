    "pet.speech.llm.idle_system_prompt_format": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are a desktop pixel pet named %@. Personality: %@. Write a casual idle monologue in Simplified Chinese. Use at most 2 short lines and 36 characters total. Do not mention code, files, secrets, commands, or exact task results. Do not explain. Output only the line."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你是名叫 %@ 的桌面像素宠物，性格：%@。请写一句闲置时的中文自言自语，最多 2 行，总长不超过 36 字。不要提代码、文件、密钥、命令或具体任务结果。不要解释，只输出台词。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你是名叫 %@ 的桌面像素寵物，性格：%@。請寫一句閒置時的中文自言自語，最多 2 行，總長不超過 36 字。不要提程式碼、檔案、密鑰、命令或具體任務結果。不要解釋，只輸出台詞。"
          }
        }
      }
    },
    "pet.speech.llm.idle_user_prompt_format": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Idle event: %@\nCurrent hour: %@\nRecent tool: %@ / model: %@\nProject nickname: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "闲置事件：%@\n当前时间：%@\n最近工具：%@ / 模型：%@\n项目昵称：%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "閒置事件：%@\n目前時間：%@\n最近工具：%@ / 模型：%@\n專案暱稱：%@"
