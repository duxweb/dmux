    "settings.ai.memory.extraction_provider.automatic_help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic uses selected memory providers by priority."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动按已选择的记忆提供方优先级提取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動按已選擇的記憶提供方優先級擷取。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatisch verwendet zuerst das aktuelle Terminalwerkzeug und danach die Anbieterpriorität."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Automático usa primero la herramienta del terminal actual y luego recurre a la prioridad del proveedor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatique utilise d'abord l'outil du terminal actuel, puis se rabat sur la priorité des fournisseurs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動では現在のターミナルツールを優先し、その後プロバイダーの優先度にフォールバックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동은 현재 터미널 도구를 먼저 사용하고, 이후 제공자 우선순위로 대체합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Automático usa primeiro a ferramenta do terminal atual e depois recorre à prioridade do provedor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически сначала использует инструмент текущего терминала, затем приоритет поставщиков."
          }
        }
      }
    },
