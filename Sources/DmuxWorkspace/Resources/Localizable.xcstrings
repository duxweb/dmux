    "settings.pet.llm.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only rhythm and milestone messages try LLM polishing. Template lines are used if it fails, times out, or no LLM channel is available."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Rhythmus- und Meilensteinmeldungen versuchen LLM-Feinschliff. Bei Fehlern, Zeitüberschreitung oder fehlendem LLM-Kanal werden Vorlagen verwendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo los mensajes de ritmo e hitos intentan usar el LLM. Se usan plantillas si falla, caduca o no hay canal LLM."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuls les messages de rythme et de jalon utilisent la retouche LLM. Les modèles sont utilisés en cas d’échec, de délai dépassé ou d’absence de canal LLM."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リズム系とマイルストーン系のメッセージだけ LLM 調整を試します。失敗、タイムアウト、LLM チャンネル未設定時はテンプレートを使います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "리듬 및 마일스톤 메시지만 LLM 다듬기를 시도합니다. 실패, 시간 초과 또는 LLM 채널이 없으면 템플릿 대사를 사용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Só mensagens de ritmo e marco tentam usar o LLM. Modelos são usados se falhar, expirar ou não houver canal LLM."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "LLM используется только для ритма и вех. При ошибке, тайм-ауте или отсутствии LLM-канала используются шаблоны."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只对节奏和里程碑类消息尝试调用；失败、超时或没有 LLM 通道时自动使用模板。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "只對節奏和里程碑類訊息嘗試呼叫；失敗、逾時或沒有 LLM 通道時自動使用範本。"
          }
        }
      }
    },
