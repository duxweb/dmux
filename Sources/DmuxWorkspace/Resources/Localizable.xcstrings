    "git.empty.loading_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the current sidebar layout while repository status syncs in the background."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留当前侧栏布局，后台同步仓库状态。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保持目前的側邊欄佈局，同時儲存庫狀態在背景同步。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalten Sie das aktuelle Seitenleistenlayout bei, während der Repository-Status im Hintergrund synchronisiert wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenga el diseño actual de la barra lateral mientras el estado del repositorio se sincroniza en segundo plano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conservez la disposition actuelle de la barre latérale pendant que l'état du référentiel se synchronise en arrière-plan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リポジトリのステータスがバックグラウンドで同期されている間、現在のサイドバーのレイアウトを維持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장소 상태가 백그라운드에서 동기화되는 동안 현재 사이드바 레이아웃을 유지합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha o layout atual da barra lateral enquanto o status do repositório é sincronizado em segundo plano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохраняйте текущий макет боковой панели, пока статус репозитория синхронизируется в фоновом режиме."
          }
        }
