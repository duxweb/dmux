        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die letzte Commit-Nachricht wurde bearbeitet. Das Remote kann einen Force-Push erfordern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se editó el mensaje del último commit. Es posible que el remoto requiera un push forzado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le message du dernier commit a été modifié. Le distant peut nécessiter un push forcé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新のコミットメッセージを編集しました。リモートには強制プッシュが必要な場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마지막 커밋 메시지를 수정했습니다. 원격에 강제 푸시가 필요할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A mensagem do último commit foi editada. O remoto pode exigir um push forçado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сообщение последнего коммита изменено. Для удалённого репозитория может потребоваться принудительный push."
          }
        }
      }
    },
