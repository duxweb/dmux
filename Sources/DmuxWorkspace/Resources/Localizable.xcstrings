    "settings.notifications.channel.bark.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send push alerts through a Bark server with your device key."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Bark 服务器和设备 Key 发送推送通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過 Bark 伺服器和裝置 Key 發送推播通知。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Push-Benachrichtigungen über einen Bark-Server mit Ihrem Geräteschlüssel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía avisos push mediante un servidor Bark con la clave de tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des alertes push via un serveur Bark avec la clé de votre appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Bark サーバーとデバイスキーを使ってプッシュ通知を送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Bark 서버와 기기 키로 푸시 알림을 보냅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia alertas push por um servidor Bark com a chave do dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет push-уведомления через сервер Bark с ключом устройства."
          }
        }
      }
    },
