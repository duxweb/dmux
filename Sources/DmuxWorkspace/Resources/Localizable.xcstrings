    "git.commit.edit_last_message.remote_notice": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only change the latest commit message. This commit may already be on the remote, so you might need to force push after editing it."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅修改最新一次提交的消息。该提交可能已经推送到远端，编辑后你可能还需要强制推送。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅修改最新一次提交訊息。這次提交可能已經推送到遠端，編輯後你可能還需要強制推送。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ändert nur die neueste Commit-Nachricht. Dieser Commit könnte bereits auf dem Remote liegen, daher musst du ihn nach der Bearbeitung möglicherweise force-pushen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo cambia el mensaje del último commit. Es posible que este commit ya esté en el remoto, así que quizá necesites forzar el push después de editarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifie uniquement le message du dernier commit. Ce commit est peut-être déjà sur le dépôt distant, vous devrez donc peut-être forcer le push après modification."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新のコミットメッセージのみを変更します。このコミットはすでにリモートへ送信されている可能性があるため、編集後に強制プッシュが必要になる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가장 최근 커밋 메시지만 수정합니다. 이 커밋이 이미 원격에 올라가 있을 수 있으므로, 수정 후 강제 푸시가 필요할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Altera apenas a mensagem do commit mais recente. Esse commit talvez já esteja no remoto, então você pode precisar forçar o push depois da edição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Изменяет только сообщение последнего коммита. Этот коммит уже может быть отправлен в удалённый репозиторий, поэтому после редактирования может понадобиться принудительная отправка."
          }
        }
      }
    },
    "git.commit.edit_last_message.remote_success": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edited the last commit message. The remote may require a force push."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已修改最后一次提交信息，远程仓库可能需要强制推送。"
