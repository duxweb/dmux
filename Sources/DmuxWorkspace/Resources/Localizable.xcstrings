    "git.auth.credentials_required": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Username and password or token cannot be empty."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "账号和密码或令牌不能为空。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用者名稱和密碼或令牌不能為空。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Benutzername und Passwort bzw. Token dürfen nicht leer sein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El nombre de usuario y la contraseña o el token no pueden estar vacíos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nom d'utilisateur et le mot de passe ou le jeton ne peuvent pas être vides."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザー名とパスワード、またはトークンを空にすることはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용자 이름과 비밀번호 또는 토큰은 비워둘 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O nome de usuário e a senha ou token não podem ficar vazios."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Имя пользователя и пароль или токен не могут быть пустыми."
          }
        }
      }
    },
