    "git.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Initialize a repository or clone a remote repository to view commits, diffs, and branches here."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "初始化仓库或克隆远程仓库后，就可以在这里查看提交、差异和分支。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "初始化儲存庫或克隆遠端儲存庫以在此處查看提交、差異和分支。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Initialisieren Sie ein Repository oder klonen Sie ein Remote-Repository, um hier Commits, Diffs und Branches anzuzeigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicialice un repositorio o clone un repositorio remoto para ver confirmaciones, diferencias y ramas aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Initialisez un référentiel ou clonez un référentiel distant pour afficher ici les validations, les différences et les branches."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リポジトリを初期化するか、リモート リポジトリのクローンを作成して、ここでコミット、差分、ブランチを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에서 커밋, 차이점, 분기를 보려면 저장소를 초기화하거나 원격 저장소를 복제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicialize um repositório ou clone um repositório remoto para visualizar commits, diferenças e ramificações aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Инициализируйте репозиторий или клонируйте удаленный репозиторий, чтобы просмотреть здесь коммиты, различия и ветки."
          }
        }
      }
    },
