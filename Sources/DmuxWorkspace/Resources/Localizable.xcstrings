    "settings.tools.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These defaults apply the next time a supported AI tool is launched inside a Codux terminal. Explicit command-line flags still take priority."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些默认值会在下次于 Codux 终端中启动受支持的 AI 工具时生效。若命令行中显式传入参数，仍以显式参数为准。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這些預設值會在下次於 Codux 終端中啟動支援的 AI 工具時生效。若命令列中明確傳入參數，仍以明確參數為準。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Standardwerte gelten beim nächsten Start eines unterstützten KI-Tools in einem Codux-Terminal. Explizite Befehlszeilenparameter haben weiterhin Vorrang."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos valores predeterminados se aplican la próxima vez que se inicie una herramienta de IA compatible dentro de un terminal de Codux. Los parámetros explícitos de la línea de comandos siguen teniendo prioridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces valeurs par défaut s'appliqueront au prochain lancement d'un outil IA pris en charge dans un terminal Codux. Les options explicites de ligne de commande restent prioritaires."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらの既定値は、対応する AI ツールを次回 Codux ターミナル内で起動したときに適用されます。コマンドラインで明示した引数がある場合は、そちらが優先されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기본값은 지원되는 AI 도구를 다음에 Codux 터미널에서 실행할 때 적용됩니다. 명시적으로 전달한 명령줄 인수는 계속 우선합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esses padrões serão aplicados na próxima vez que uma ferramenta de IA compatível for iniciada em um terminal do Codux. Parâmetros explícitos da linha de comando continuam tendo prioridade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эти значения по умолчанию будут применены при следующем запуске поддерживаемого AI-инструмента в терминале Codux. Явно переданные параметры командной строки по-прежнему имеют приоритет."
          }
        }
      }
    },
