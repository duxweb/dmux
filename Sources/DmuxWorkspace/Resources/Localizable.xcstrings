    "pet.claim.voidcat.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A black cat that loves long thoughts in the middle of the night."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一只喜欢深夜里的长段思考的黑猫。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一隻喜歡深夜裡長段思考的黑貓。"
          }
        }
      }
    },
    "pet.claim.rusthound.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It falls over, gets up again, and keeps going anyway."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跌倒了就再来一次，反正耳朵已经歪了一只。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "跌倒了就再來一次，反正耳朵已經歪了一隻。"
          }
        }
      }
    },
    "pet.claim.goose.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It doesn't fully get what's happening, but it also doesn't mind."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不太懂发生了什么，但也不太在意。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不太懂發生了什麼，但也不太在意。"
          }
        }
      }
    },
    "pet.claim.random.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave it to fate. A random egg can hatch the hidden species."
