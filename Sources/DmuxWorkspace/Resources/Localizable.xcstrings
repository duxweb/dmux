    "settings.notifications.channel.webhook.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send JSON POST requests to your own endpoint. Add a bearer token if the receiver requires authorization."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向自定义端点发送 JSON POST 请求；如接收方要求鉴权可填写 Bearer Token。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "向自訂端點發送 JSON POST 請求；如接收方要求驗證可填寫 Bearer Token。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet JSON-POST-Anfragen an Ihren eigenen Endpunkt. Fügen Sie ein Bearer-Token hinzu, wenn der Empfänger eine Autorisierung verlangt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía solicitudes JSON POST a tu propio endpoint. Añade un bearer token si el receptor requiere autorización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des requêtes POST JSON à votre propre point de terminaison. Ajoutez un bearer token si le destinataire exige une autorisation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "独自のエンドポイントへ JSON POST リクエストを送信します。受信側で認証が必要な場合は Bearer Token を入力します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용자 지정 엔드포인트로 JSON POST 요청을 보냅니다. 수신 측에서 인증이 필요하면 Bearer Token을 입력합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia requisições JSON POST para seu próprio endpoint. Adicione um bearer token se o destino exigir autorização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет JSON POST-запросы на ваш собственный endpoint. Добавьте Bearer Token, если получатель требует авторизацию."
          }
        }
      }
    },
