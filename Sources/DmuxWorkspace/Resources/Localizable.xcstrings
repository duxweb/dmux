    "settings.notifications.channel.wecom.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Post messages to a WeCom group bot. You can fill either the full URL or the webhook key."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用企业微信群机器人发送消息，可填写完整 Webhook 地址或 Webhook Key。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用企業微信群機器人發送訊息，可填寫完整 Webhook 位址或 Webhook Key。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Nachrichten an einen WeCom-Gruppen-Bot. Sie können die vollständige URL oder den Webhook-Schlüssel eintragen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía mensajes a un bot de grupo de WeCom. Puedes completar la URL completa o la clave del webhook."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des messages à un bot de groupe WeCom. Vous pouvez renseigner l'URL complète ou la clé du webhook."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "WeCom グループボットへメッセージを送信します。完全な URL または Webhook Key を入力できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "WeCom 그룹 봇으로 메시지를 보냅니다. 전체 URL 또는 Webhook Key를 입력할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia mensagens para um bot de grupo do WeCom. Você pode informar a URL completa ou a chave do webhook."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет сообщения в группового бота WeCom. Можно указать полный URL или ключ webhook."
          }
        }
      }
    },
