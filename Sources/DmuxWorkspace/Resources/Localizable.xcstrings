    "settings.notifications.channel.ntfy.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Publish messages to an ntfy topic. Add a bearer token only when your server requires it."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发布消息到 ntfy 主题；仅在服务端要求时填写 Bearer Token。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發布訊息到 ntfy 主題；僅在服務端要求時填寫 Bearer Token。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Veröffentlicht Nachrichten in einem ntfy-Thema. Fügen Sie nur dann ein Bearer-Token hinzu, wenn Ihr Server es verlangt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Publica mensajes en un tema de ntfy. Añade un bearer token solo si tu servidor lo requiere."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Publie des messages dans un sujet ntfy. Ajoutez un bearer token uniquement si votre serveur l'exige."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ntfy トピックにメッセージを配信します。Bearer Token はサーバーが必要とする場合のみ入力します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ntfy 토픽으로 메시지를 게시합니다. Bearer Token은 서버가 요구할 때만 입력합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Publica mensagens em um tópico do ntfy. Adicione um bearer token apenas se o servidor exigir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Публикует сообщения в тему ntfy. Добавляйте Bearer Token только если этого требует сервер."
          }
        }
      }
    },
