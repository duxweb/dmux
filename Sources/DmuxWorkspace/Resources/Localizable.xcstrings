    "settings.notifications.channel.feishu.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Post messages with a Feishu bot webhook. You can fill either the full URL or the hook token."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用飞书机器人 Webhook 发送消息，可填写完整 Webhook 地址或 Hook Token。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用飛書機器人 Webhook 發送訊息，可填寫完整 Webhook 位址或 Hook Token。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Nachrichten über einen Feishu-Bot-Webhook. Sie können die vollständige URL oder das Hook-Token eintragen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía mensajes con un webhook de bot de Feishu. Puedes completar la URL completa o el hook token."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des messages avec un webhook de bot Feishu. Vous pouvez renseigner l'URL complète ou le hook token."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Feishu ボットの Webhook でメッセージを送信します。完全な URL または Hook Token を入力できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Feishu 봇 Webhook으로 메시지를 보냅니다. 전체 URL 또는 Hook Token을 입력할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia mensagens com um webhook de bot do Feishu. Você pode informar a URL completa ou o hook token."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет сообщения через webhook-бота Feishu. Можно указать полный URL или hook token."
          }
        }
      }
    },
