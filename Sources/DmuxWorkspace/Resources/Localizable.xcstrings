    "memory.status.local_input_too_long_detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory input exceeded the local model context window. Codux will compact and retry it automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记忆输入超过了本地模型上下文窗口。Codux 会自动压缩并重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶輸入超過了本地模型上下文視窗。Codux 會自動壓縮並重試。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Speichereingabe war größer als das Kontextfenster des lokalen Modells. Codux komprimiert sie und versucht es automatisch erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrada de memoria superó la ventana de contexto del modelo local. Codux la compactará y reintentará automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’entrée mémoire dépasse la fenêtre de contexte du modèle local. Codux va la compacter et réessayer automatiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリ入力がローカルモデルのコンテキスト上限を超えました。Codux が自動で圧縮して再試行します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리 입력이 로컬 모델의 컨텍스트 창을 초과했습니다. Codux가 자동으로 압축해 다시 시도합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A entrada de memória excedeu a janela de contexto do modelo local. O Codux vai compactar e tentar novamente automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ввод памяти превысил контекстное окно локальной модели. Codux сожмет его и повторит попытку автоматически."
          }
        }
      }
    },
