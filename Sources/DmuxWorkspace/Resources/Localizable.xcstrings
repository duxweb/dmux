    "pet.speech.catalog.fallback_line": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe es gesehen. Weiter so."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I saw it. Keep going."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo vi. Sigue."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je l’ai vu. Continue."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "見てたよ。続けて。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "봤어. 계속해."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Eu vi. Continue."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я видел. Продолжай."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我看到了，继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我看到了，繼續。"
          }
        }
      }
    },
    "pet.speech.catalog.roast.openers": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tss. \nSchon wieder? \nSag mal. \nNa schön. \nKlar. \nAha. \nIch seh dich. \nGleiche Show. "
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tch. \nAgain? \nListen. \nFine. \nSure. \nWow. \nEyes on you. \nSame act. "
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pff. \n¿Otra vez? \nA ver. \nVale. \nClaro. \nVaya. \nTe veo. \nLa misma. "
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pff. \nEncore ? \nDis donc. \nBon. \nVoilà. \nTiens. \nJe te vois. \nMême numéro. "
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ちっ、\nまた？\nねえ、\nはいはい、\nふーん、\nへぇ、\n見てるよ、\n同じ展開、"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "쯧,\n또 시작?\n이봐,\n그래그래,\n흐음,\n어머,\n지켜본다,\n또 그거?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tch. \nDe novo? \nOlha só. \nTá bom. \nClaro. \nNossa. \nDe olho. \nA mesma. "
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тц. \nОпять? \nСлушай. \nЛадно. \nДа уж. \nНу-ну. \nСмотрю. \nТо же самое. "
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "啧，\n又来，\n我说，\n真行，\n得，\n服了，\n盯着你，\n老演员，"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "嘖，\n又來，\n我說，\n真行，\n得，\n服了，\n盯著你，\n老演員，"
          }
        }
      }
    },
    "pet.speech.catalog.roast.fallbacks": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schon wieder dabei.\nViel Lärm, mittelmäßig.\nGerade so durchgekommen.\nNoch nicht angeben, bitte.\nGesehen. Ich halt mich zurück.\nDas hat geklappt? Mutig.\nGleiches Drehbuch wie immer.\nTun als ob? Ich hab's gesehen.\nKreativer Schachzug, hm.\nHör auf, ich lach gleich.\nGut, kommt in deine Akte.\nGelassen tun hilft dir nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At it again, are we.\nLoud effort, mid result.\nBarely pulled that off.\nDon't go bragging yet.\nSaw that. Holding it in.\nWow, that worked? Bold.\nSame script as last time.\nPretending I didn't see? Saw.\nCreative move there.\nStop, I'll laugh.\nFine. Adding to your file.\nActing casual won't help."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Otra vez con esto.\nMucho ruido, resultado normal.\nApenas pasó esta vez.\nNo presumas todavía.\nLo vi. Me lo guardo.\n¿Funcionó? Atrevido.\nMismo guion de siempre.\n¿Disimulando? Lo vi.\nMovimiento creativo, vaya.\nPara, me voy a reír.\nVale, lo anoto en tu ficha.\nHacerse el normal no cuela."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "On remet ça, hein.\nGrand bruit, résultat moyen.\nPassé de justesse.\nNe te vante pas trop vite.\nVu. Je me retiens.\nÇa marche ? Audacieux.\nMême scénario qu'avant.\nFaire semblant ? J'ai vu.\nMouvement créatif, ça.\nArrête, je vais rire.\nBon, je note dans ton dossier.\nFaire le détaché, ça marche pas."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "また始まった。\n大騒ぎして結果は普通。\nギリギリ通過、ほんと。\nまだ自慢しないで。\n見たよ、黙っとくけど。\nこれで通る？大胆。\n同じ脚本、また？\nバレてないつもり？バレてる。\nなかなか独創的な手。\nやめて、笑っちゃう。\nはいはい、記録します。\n知らんぷりは無理だよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "또 시작이네.\n요란하더니 결과는 그저.\n간신히 넘겼네, 진짜.\n자랑은 아직 일러.\n봤어. 일단 참는다.\n이게 통하다니 대단.\n같은 대본 또 봐?\n못 본 척? 다 봤어.\n창의적인 무브야.\n그만, 웃을 거 같아.\n그래그래, 기록해 둔다.\n시치미 떼도 소용없어."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Lá vamos nós de novo.\nMuito barulho, resultado mediano.\nPassou raspando, hein.\nNão se gabe ainda não.\nVi. Vou guardar.\nFuncionou? Arriscado.\nMesmo roteiro de sempre.\nDisfarçando? Já vi.\nJogada criativa, viu.\nPara, vou rir.\nTá, anotei na sua ficha.\nFingir tranquilidade não cola."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опять за своё, да.\nШума много, толку средне.\nЕдва прошло, ну-ну.\nХвастаться рано пока.\nВидел. Промолчу.\nСработало? Смело.\nТот же сценарий снова.\nДелаешь вид? Я видел.\nКреативный ход, ага.\nХватит, я засмеюсь.\nЛадно, записал в твоё дело.\nДелать вид не выйдет."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "又开摆了是吧。\n动静不小，结果一般。\n勉强算你扛过去了。\n别急着发朋友圈。\n我看见了，先憋着。\n这都能行，奇了。\n老剧本又演一遍。\n当我没看见？看见了。\n你这操作很有想法。\n再吹我就笑出声。\n行行行，记你一笔。\n装作没事就过得去？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "又開擺了是吧。\n動靜不小，結果一般。\n勉強算你扛過去了。\n別急著發朋友圈。\n我看見了，先憋著。\n這都能行，奇了。\n老劇本又演一遍。\n當我沒看見？看見了。\n你這操作很有想法。\n再吹我就笑出聲。\n行行行，記你一筆。\n裝作沒事就過得去？"
          }
        }
      }
    },
    "pet.speech.catalog.roast.cores": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} startet. Nicht abhauen.\nturn.completed={tool} fertig. Knapp bestanden.\nturn.completedFast={tool} in {durationSec}? Glück.\nturn.completedLong={tool}: {durationMin}min. Lahm.\nturn.needsInput={tool} hängt. Rette es.\nturn.interrupted={tool} unterbrochen. Peinlich.\ntool.switched={prevTool} weg, {tool} dran.\ntokens.burst={tool} fraß {tokensK}. Hungrig.\nnight.entered={hourLabel} und noch wach.\nidle.returned={minutesAway}min weg. Endlich da.\ntool.multiStreak={toolList} offen. Angeber.\npet.levelUp=Lv.{level}. Nicht überrascht tun.\npet.statBreakthrough={stat} über {value}. Krass.\nusage.dailyRecord={tokensK} heute. Vielfraß.\nreminder.hydration={durationMin}min. Glas ist Deko?\nreminder.sedentary={durationMin}min. Beine weg.\nreminder.lateNight={hourLabel}. Ab ins Bett."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} started. Don't ghost it.\nturn.completed={tool} done. Barely passes.\nturn.completedFast={tool} in {durationSec}? Lucky.\nturn.completedLong={tool}: {durationMin}min. Slow.\nturn.needsInput={tool} froze. Save it, hero.\nturn.interrupted={tool} cut off. Awkward.\ntool.switched={prevTool} out, {tool} in.\ntokens.burst={tool} ate {tokensK}. Hungry.\nnight.entered={hourLabel} and still up.\nidle.returned=Gone {minutesAway}min. Finally back.\ntool.multiStreak={toolList} all open. Showoff.\npet.levelUp=Lv.{level}. Don't act surprised.\npet.statBreakthrough={stat} past {value}. Wild.\nusage.dailyRecord={tokensK} today. Glutton.\nreminder.hydration={durationMin}min in. Water? No?\nreminder.sedentary=Sat {durationMin}min. Legs gone.\nreminder.lateNight={hourLabel}. Sleep, drama queen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} arrancó. No te escapes.\nturn.completed={tool} listo. Apenas pasa.\nturn.completedFast={tool} en {durationSec}? Suerte.\nturn.completedLong={tool}: {durationMin}min. Lento.\nturn.needsInput={tool} colgado. Sálvalo.\nturn.interrupted={tool} cortado. Incómodo.\ntool.switched={prevTool} fuera, {tool} dentro.\ntokens.burst={tool} comió {tokensK}. Glotón.\nnight.entered={hourLabel} y aún despierto.\nidle.returned={minutesAway}min fuera. Volviste.\ntool.multiStreak={toolList} abiertos. Fardas.\npet.levelUp=Lv.{level}. Sin sorpresa fingida.\npet.statBreakthrough={stat} pasó {value}. Locura.\nusage.dailyRecord={tokensK} hoy. Tragón.\nreminder.hydration={durationMin}min. ¿Vaso? Adorno.\nreminder.sedentary={durationMin}min. Sin piernas.\nreminder.lateNight={hourLabel}. A dormir, drama."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} part. Pas de fugue.\nturn.completed={tool} fini. À peine passable.\nturn.completedFast={tool} en {durationSec} ? Veinard.\nturn.completedLong={tool} : {durationMin}min. Lent.\nturn.needsInput={tool} bloqué. À toi.\nturn.interrupted={tool} coupé. Gênant.\ntool.switched={prevTool} part, {tool} arrive.\ntokens.burst={tool} a bu {tokensK}. Affamé.\nnight.entered={hourLabel} et toujours là.\nidle.returned={minutesAway}min parti. Te revoilà.\ntool.multiStreak={toolList} ouverts. Frime.\npet.levelUp=Lv.{level}. Fais pas semblant.\npet.statBreakthrough={stat} passe {value}. Fou.\nusage.dailyRecord={tokensK} aujourd'hui. Glouton.\nreminder.hydration={durationMin}min. Le verre ? Déco.\nreminder.sedentary={durationMin}min. Plus de jambes.\nreminder.lateNight={hourLabel}. Dors, princesse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}開始。逃げないでよ。\nturn.completed={tool}終わり。ギリ合格。\nturn.completedFast={tool}{durationSec}？運じゃ？\nturn.completedLong={tool}に{durationMin}分。遅っ。\nturn.needsInput={tool}固まった。助けて。\nturn.interrupted={tool}途中で切れた。微妙。\ntool.switched={prevTool}から{tool}。また？\ntokens.burst={tool}が{tokensK}飲んだ。大食い。\nnight.entered={hourLabel}まだ起きてる。\nidle.returned={minutesAway}分消えてた、お帰り。\ntool.multiStreak={toolList}全開放。見せつけ？\npet.levelUp=Lv.{level}。驚いた振り無理。\npet.statBreakthrough={stat}が{value}超え。やば。\nusage.dailyRecord=今日{tokensK}。食欲旺盛ね。\nreminder.hydration={durationMin}分経過。水は飾り？\nreminder.sedentary={durationMin}分着席。脚消失。\nreminder.lateNight={hourLabel}、寝なさい。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} 시작. 도망 금지.\nturn.completed={tool} 끝. 간신히 통과.\nturn.completedFast={tool} {durationSec}? 운이지.\nturn.completedLong={tool} {durationMin}분 끌었네.\nturn.needsInput={tool} 멈췄다. 구해줘.\nturn.interrupted={tool} 중단. 어색해.\ntool.switched={prevTool} 빠지고 {tool} 등판.\ntokens.burst={tool} {tokensK} 먹음. 대식가.\nnight.entered={hourLabel}, 아직 안 자?\nidle.returned={minutesAway}분 사라졌다 복귀.\ntool.multiStreak={toolList} 다 켜놨네. 과시.\npet.levelUp=Lv.{level}. 놀란 척 말고.\npet.statBreakthrough={stat} {value} 돌파.\nusage.dailyRecord=오늘 {tokensK}. 잘 먹네.\nreminder.hydration={durationMin}분째. 컵 장식?\nreminder.sedentary={durationMin}분 앉음. 다리 소실.\nreminder.lateNight={hourLabel}, 그만 자."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} começou. Não some.\nturn.completed={tool} pronto. Mal passou.\nturn.completedFast={tool} em {durationSec}? Sorte.\nturn.completedLong={tool}: {durationMin}min. Lento.\nturn.needsInput={tool} travou. Salva aí.\nturn.interrupted={tool} cortado. Que mico.\ntool.switched={prevTool} sai, {tool} entra.\ntokens.burst={tool} comeu {tokensK}. Faminto.\nnight.entered={hourLabel} e ainda acordado.\nidle.returned={minutesAway}min sumido. Voltou.\ntool.multiStreak={toolList} abertos. Exibido.\npet.levelUp=Lv.{level}. Sem fingir surpresa.\npet.statBreakthrough={stat} passou {value}.\nusage.dailyRecord={tokensK} hoje. Glutão.\nreminder.hydration={durationMin}min. Copo? Enfeite.\nreminder.sedentary={durationMin}min. Sem pernas.\nreminder.lateNight={hourLabel}. Dorme, drama."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} стартовал. Не сбегай.\nturn.completed={tool} готов. Едва прошёл.\nturn.completedFast={tool} за {durationSec}? Везуха.\nturn.completedLong={tool}: {durationMin}мин. Тормоз.\nturn.needsInput={tool} завис. Спасай.\nturn.interrupted={tool} оборван. Неловко.\ntool.switched={prevTool} ушёл, {tool} зашёл.\ntokens.burst={tool} съел {tokensK}. Прожорлив.\nnight.entered={hourLabel} и не спишь.\nidle.returned={minutesAway}мин не было. Явился.\ntool.multiStreak={toolList} включены. Хвастун.\npet.levelUp=Lv.{level}. Не делай вид.\npet.statBreakthrough={stat} за {value}. Дикость.\nusage.dailyRecord={tokensK} сегодня. Обжора.\nreminder.hydration={durationMin}мин. Стакан-декор?\nreminder.sedentary={durationMin}мин. Ноги ушли.\nreminder.lateNight={hourLabel}. Спать, драма."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}开活了，别又开溜。\nturn.completed={tool}干完，勉强能看。\nturn.completedFast={tool}{durationSec}就好？运气吧。\nturn.completedLong={tool}磨{durationMin}分钟才挤出来。\nturn.needsInput={tool}卡了，靠你救场。\nturn.interrupted={tool}没演完，尴尬一下。\ntool.switched={prevTool}下{tool}上，又换菜。\nidle.monologue=没动静，反而更可疑。\ntokens.burst={tool}吃了{tokensK}，真能造。\nnight.entered={hourLabel}还在熬，爱熬夜。\nidle.returned=走了{minutesAway}分钟才舍得回。\ntool.multiStreak={toolList}都开，热闹给谁看。\npet.levelUp=Lv.{level}了，别装没看见。\npet.statBreakthrough={stat}破{value}，离谱进度。\nusage.dailyRecord=今天{tokensK}，喂得真饱。\nreminder.hydration=干了{durationMin}分钟，水杯摆设。\nreminder.sedentary=坐了{durationMin}分钟，腿没了。\nreminder.lateNight={hourLabel}了还冲，别先躺了。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}開活了，別又開溜。\nturn.completed={tool}幹完，勉強能看。\nturn.completedFast={tool}{durationSec}就好？運氣吧。\nturn.completedLong={tool}磨{durationMin}分鐘才擠出來。\nturn.needsInput={tool}卡了，靠你救場。\nturn.interrupted={tool}沒演完，尷尬一下。\ntool.switched={prevTool}下{tool}上，又換菜。\nidle.monologue=沒動靜，反而更可疑。\ntokens.burst={tool}吃了{tokensK}，真能造。\nnight.entered={hourLabel}還在熬，愛熬夜。\nidle.returned=走了{minutesAway}分鐘才捨得回。\ntool.multiStreak={toolList}都開，熱鬧給誰看。\npet.levelUp=Lv.{level}了，別裝沒看見。\npet.statBreakthrough={stat}破{value}，離譜進度。\nusage.dailyRecord=今天{tokensK}，餵得真飽。\nreminder.hydration=幹了{durationMin}分鐘，水杯擺設。\nreminder.sedentary=坐了{durationMin}分鐘，腿沒了。\nreminder.lateNight={hourLabel}了還衝，別先躺了。"
          }
        }
      }
    },
    "pet.speech.catalog.encourage.openers": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesehen. \nJa. \nSchön. \nLass dir Zeit. \nIch bin da. \nGanz ruhig. \nGut so. \nBei dir. "
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saw it. \nYep. \nNice. \nTake your time. \nI'm here. \nEasy now. \nPretty good. \nRight with you. "
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo vi. \nSí. \nBien. \nSin prisa. \nAquí estoy. \nTranqui. \nNada mal. \nContigo. "
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vu. \nOui. \nJoli. \nPrends ton temps. \nJe suis là. \nTout doux. \nPas mal. \nAvec toi. "
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "見たよ、\nうん、\nこの一手、\nゆっくり、\nここにいる、\n焦らずに、\nいい感じ、\n一緒だよ、"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "봤어,\n응,\n이번 거,\n천천히,\n여기 있어,\n급할 거 없어,\n괜찮아,\n같이 있을게,"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi. \nSim. \nLegal. \nSem pressa. \nTô aqui. \nCalma. \nNada mal. \nCom você. "
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Видел. \nДа. \nНеплохо. \nНе спеши. \nЯ здесь. \nСпокойно. \nХорошо. \nС тобой. "
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "看到了，\n嗯，\n这一下，\n慢慢来，\n我在，\n别催自己，\n挺不错，\n陪你呢，"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "看到了，\n嗯，\n這一下，\n慢慢來，\n我在，\n別催自己，\n挺不錯，\n陪你呢，"
          }
        }
      }
    },
    "pet.speech.catalog.encourage.fallbacks": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich schau. Keine Eile.\nDieser Schritt war fest.\nDein Tempo zählt.\nHängen? Pause ist okay.\nSchief? Wird angepasst.\nEine Pause ist okay.\nDu bewegst dich. Reicht.\nBis hier ist schon viel.\nGut genug ist gut.\nKleine Schritte zählen.\nIch bleib bei dir.\nAtme, wenn du musst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm watching. No rush.\nThat step felt solid.\nSet your own pace.\nStuck is fine. Pause.\nOff course? Just adjust.\nTaking a break is fine.\nYou're moving. That's enough.\nGetting here already counts.\nGood enough is good.\nSmall steps still count.\nI'll sit with you.\nBreathe if you need to."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te miro. Sin prisa.\nEse paso fue firme.\nTu ritmo, tú decides.\n¿Atascado? Pausa, vale.\n¿Desviado? Se ajusta.\nDescansar está bien.\nEstás moviéndote, suficiente.\nLlegar aquí ya cuenta.\nLo suficiente vale.\nPasos pequeños cuentan.\nAquí contigo.\nRespira si lo necesitas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je regarde. Pas de hâte.\nCe pas était solide.\nVa à ton rythme.\nBloqué ? Pause, c'est bon.\nDévié ? On rectifie.\nUne pause, ça va.\nTu avances. C'est assez.\nArriver là, ça compte.\nAssez bon, c'est bon.\nPetits pas, ça compte.\nJe reste avec toi.\nRespire si besoin."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "見てるよ、慌てないで。\n今のは確かな一歩。\n自分のペースでいい。\n止まっても大丈夫。\nずれたら直せばいい。\n休んでもいいよ。\n動いてる、それで十分。\nここまで来た、すごい。\nほどほどで充分。\n小さな一歩も数える。\nそばにいるよ。\n息ついていいよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보고 있어, 천천히 해.\n방금 그 한 걸음 단단해.\n페이스는 네가 정해.\n막혀도 괜찮아, 멈춰.\n틀어졌으면 다시 맞춰.\n쉬어도 괜찮아.\n움직이고 있어, 충분해.\n여기까지 온 것도 대단.\n적당히면 충분해.\n작은 걸음도 친다.\n함께 있을게.\n숨 좀 쉬어도 돼."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tô olhando. Sem pressa.\nEsse passo foi firme.\nSeu ritmo, você decide.\nTravou? Pausa, tudo bem.\nSaiu da rota? Ajusta.\nDescansar tá ok.\nVocê se mexe. Já basta.\nChegar aqui já vale.\nBom o bastante vale.\nPassos pequenos contam.\nTô do seu lado.\nRespira se precisar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотрю. Не спеши.\nЭтот шаг был твёрдым.\nТвой темп, ты решаешь.\nЗастрял? Пауза — норм.\nСбился? Подкорректируй.\nОтдохнуть можно.\nДвигаешься. Этого хватит.\nДойти сюда — уже зачёт.\nДостаточно — это хорошо.\nМаленькие шаги считаются.\nЯ рядом.\nПодыши, если надо."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我盯着呢，你慢慢来。\n这一下挺扎实的。\n节奏自己定，别抢。\n卡住就先放一放。\n歪了再调，没关系。\n停一会也没事。\n你已经在动了，够。\n做到这步就不容易。\n差不多就行，别较真。\n小步也算数的。\n我陪你这一段。\n想喘口气就喘。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我盯著呢，你慢慢來。\n這一下挺扎實的。\n節奏自己定，別搶。\n卡住就先放一放。\n歪了再調，沒關係。\n停一會也沒事。\n你已經在動了，夠。\n做到這步就不容易。\n差不多就行，別較真。\n小步也算數的。\n我陪你這一段。\n想喘口氣就喘。"
          }
        }
      }
    },
    "pet.speech.catalog.encourage.cores": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} läuft. Ich bin da.\nturn.completed={tool} fertig. Solider Schritt.\nturn.completedFast={tool} in {durationSec}. Flott.\nturn.completedLong={tool}: {durationMin}min. Geschafft.\nturn.needsInput={tool} wartet auf dich.\nturn.interrupted={tool} steht. Durchatmen.\ntool.switched={prevTool} → {tool}.\ntokens.burst={tool} schob {tokensK}.\nnight.entered={hourLabel} und noch dabei.\nidle.returned=Nach {minutesAway}min zurück.\ntool.multiStreak={toolList} parallel, stabil.\npet.levelUp=Lv.{level} erreicht.\npet.statBreakthrough={stat} bei {value}.\nusage.dailyRecord={tokensK} heute. Rekord.\nreminder.hydration={durationMin}min ohne Wasser.\nreminder.sedentary={durationMin}min. Streck dich.\nreminder.lateNight={hourLabel}. Bald Schluss?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} is going. I'm here.\nturn.completed={tool} done. Solid step.\nturn.completedFast={tool}, {durationSec}. Snappy.\nturn.completedLong={tool}: {durationMin}min, got there.\nturn.needsInput={tool} waiting on you.\nturn.interrupted={tool} stopped. Breathe.\ntool.switched={prevTool} → {tool}. Smooth.\ntokens.burst={tool}: {tokensK}. Big push.\nnight.entered={hourLabel} and still here.\nidle.returned=Back after {minutesAway}min.\ntool.multiStreak={toolList} all running.\npet.levelUp=Lv.{level} unlocked.\npet.statBreakthrough={stat} hit {value}.\nusage.dailyRecord={tokensK} today. New high.\nreminder.hydration={durationMin}min, drink.\nreminder.sedentary=Sat {durationMin}min. Stretch.\nreminder.lateNight={hourLabel}. Wrap up soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} arranca. Aquí estoy.\nturn.completed={tool} listo. Paso firme.\nturn.completedFast={tool} en {durationSec}. Ágil.\nturn.completedLong={tool}: {durationMin}min. Llegaste.\nturn.needsInput={tool} te espera.\nturn.interrupted={tool} parado. Respira.\ntool.switched={prevTool} a {tool}.\ntokens.burst={tool} avanzó {tokensK}.\nnight.entered={hourLabel} y aún aquí.\nidle.returned=Vuelves tras {minutesAway}min.\ntool.multiStreak={toolList} a la vez.\npet.levelUp=Lv.{level} alcanzado.\npet.statBreakthrough={stat} llega a {value}.\nusage.dailyRecord={tokensK} hoy. Récord.\nreminder.hydration={durationMin}min sin agua.\nreminder.sedentary={durationMin}min. Estírate.\nreminder.lateNight={hourLabel}. ¿Cerramos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} démarre. Je suis là.\nturn.completed={tool} fini. Pas solide.\nturn.completedFast={tool} en {durationSec}. Vif.\nturn.completedLong={tool} : {durationMin}min, arrivé.\nturn.needsInput={tool} t'attend.\nturn.interrupted={tool} arrêté. Souffle.\ntool.switched={prevTool} → {tool}.\ntokens.burst={tool} a poussé {tokensK}.\nnight.entered={hourLabel} et tu tiens.\nidle.returned={minutesAway}min après, retour.\ntool.multiStreak={toolList} en parallèle.\npet.levelUp=Lv.{level} atteint.\npet.statBreakthrough={stat} touche {value}.\nusage.dailyRecord={tokensK} aujourd'hui. Top.\nreminder.hydration={durationMin}min sans eau.\nreminder.sedentary=Assis {durationMin}min. Étire.\nreminder.lateNight={hourLabel}. On termine ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}始動。一緒にいるよ。\nturn.completed={tool}完了。確かな一歩。\nturn.completedFast={tool}{durationSec}で完了、軽快。\nturn.completedLong={tool}に{durationMin}分。到達。\nturn.needsInput={tool}があなた待ち。\nturn.interrupted={tool}停止。一息ついて。\ntool.switched={prevTool}から{tool}へ。\ntokens.burst={tool}が{tokensK}進めた。実り。\nnight.entered={hourLabel}、まだ一緒だね。\nidle.returned={minutesAway}分でお帰り。\ntool.multiStreak={toolList}並走、安定。\npet.levelUp=Lv.{level}達成。\npet.statBreakthrough={stat}が{value}到達。\nusage.dailyRecord=今日{tokensK}、新記録。\nreminder.hydration={durationMin}分、水を一口。\nreminder.sedentary={durationMin}分着席、伸びを。\nreminder.lateNight={hourLabel}、そろそろ区切り。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} 시작. 함께해.\nturn.completed={tool} 완료. 단단한 한 걸음.\nturn.completedFast={tool} {durationSec}. 깔끔.\nturn.completedLong={tool} {durationMin}분, 도달.\nturn.needsInput={tool} 너를 기다려.\nturn.interrupted={tool} 멈춤. 숨 고르고.\ntool.switched={prevTool} → {tool}.\ntokens.burst={tool} {tokensK} 진행.\nnight.entered={hourLabel}, 아직 같이.\nidle.returned={minutesAway}분 만에 복귀.\ntool.multiStreak={toolList} 동시에. 안정.\npet.levelUp=Lv.{level} 달성.\npet.statBreakthrough={stat} {value} 도달.\nusage.dailyRecord=오늘 {tokensK}, 신기록.\nreminder.hydration={durationMin}분 됐어, 한 모금.\nreminder.sedentary={durationMin}분 앉음. 기지개.\nreminder.lateNight={hourLabel}, 슬슬 마무리."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} começou. Tô aqui.\nturn.completed={tool} pronto. Passo firme.\nturn.completedFast={tool} em {durationSec}. Ágil.\nturn.completedLong={tool}: {durationMin}min. Chegou.\nturn.needsInput={tool} esperando você.\nturn.interrupted={tool} parou. Respira.\ntool.switched={prevTool} pra {tool}.\ntokens.burst={tool} avançou {tokensK}.\nnight.entered={hourLabel} e ainda aqui.\nidle.returned={minutesAway}min e voltou.\ntool.multiStreak={toolList} ao mesmo tempo.\npet.levelUp=Lv.{level} alcançado.\npet.statBreakthrough={stat} chega em {value}.\nusage.dailyRecord={tokensK} hoje. Recorde.\nreminder.hydration={durationMin}min sem água.\nreminder.sedentary={durationMin}min. Alonga.\nreminder.lateNight={hourLabel}. Encerrar?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} запущен. Я рядом.\nturn.completed={tool} готов. Твёрдый шаг.\nturn.completedFast={tool} за {durationSec}. Шустро.\nturn.completedLong={tool}: {durationMin}мин. Дошли.\nturn.needsInput={tool} ждёт тебя.\nturn.interrupted={tool} стоит. Подыши.\ntool.switched={prevTool} → {tool}.\ntokens.burst={tool} прошёл {tokensK}.\nnight.entered={hourLabel} и всё здесь.\nidle.returned={minutesAway}мин — вернулся.\ntool.multiStreak={toolList} параллельно.\npet.levelUp=Lv.{level} взят.\npet.statBreakthrough={stat} достиг {value}.\nusage.dailyRecord={tokensK} сегодня. Рекорд.\nreminder.hydration={durationMin}мин без воды.\nreminder.sedentary={durationMin}мин. Разомнись.\nreminder.lateNight={hourLabel}. Пора закругляться."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}开干了，我陪着。\nturn.completed={tool}收工，干得不错。\nturn.completedFast={tool}{durationSec}就好，挺利落。\nturn.completedLong={tool}磨{durationMin}分钟，到了。\nturn.needsInput={tool}在等你呢，搭一句。\nturn.interrupted={tool}停了，喘口气再来。\ntool.switched={prevTool}换{tool}，挺顺。\nidle.monologue=我还在这儿，慢慢来。\ntokens.burst={tool}冲了{tokensK}，挺猛。\nnight.entered={hourLabel}还没下班啊。\nidle.returned=走开{minutesAway}分钟，回来啦。\ntool.multiStreak={toolList}都挂着，挺能扛。\npet.levelUp=升到Lv.{level}啦。\npet.statBreakthrough={stat}到{value}了，攒出来的。\nusage.dailyRecord=今天{tokensK}，新高。\nreminder.hydration={durationMin}分钟没喝水了。\nreminder.sedentary=坐{durationMin}分钟啦，伸个腰。\nreminder.lateNight={hourLabel}了，差不多歇吧。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}開幹了，我陪著。\nturn.completed={tool}收工，幹得不錯。\nturn.completedFast={tool}{durationSec}就好，挺俐落。\nturn.completedLong={tool}磨{durationMin}分鐘，到了。\nturn.needsInput={tool}在等你呢，搭一句。\nturn.interrupted={tool}停了，喘口氣再來。\ntool.switched={prevTool}換{tool}，挺順。\nidle.monologue=我還在這兒，慢慢來。\ntokens.burst={tool}衝了{tokensK}，挺猛。\nnight.entered={hourLabel}還沒下班啊。\nidle.returned=走開{minutesAway}分鐘，回來啦。\ntool.multiStreak={toolList}都掛著，挺能扛。\npet.levelUp=升到Lv.{level}啦。\npet.statBreakthrough={stat}到{value}了，攢出來的。\nusage.dailyRecord=今天{tokensK}，新高。\nreminder.hydration={durationMin}分鐘沒喝水了。\nreminder.sedentary=坐{durationMin}分鐘啦，伸個腰。\nreminder.lateNight={hourLabel}了，差不多歇吧。"
          }
        }
      }
    },
    "pet.speech.catalog.flirty.openers": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey. \nErwischt. \nMhm. \nNicht übel. \nIch seh dich. \nNotiert. \nNäher ran. \nNiedlich. "
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hey. \nCaught you. \nMmm. \nNot bad. \nEyes on you. \nNoted. \nCloser now. \nAw. "
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eh. \nTe pillé. \nMm. \nNada mal. \nMirándote. \nApuntado. \nMás cerca. \nAy. "
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hé. \nJe te tiens. \nMmh. \nPas mal. \nJe t'observe. \nNoté. \nApproche. \nMignon. "
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ねえ、\n見つけた、\nふふ、\nいい感じ、\n目が離せない、\nメモ、\nもっと近く、\nきゅん、"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "있잖아,\n잡았다,\n흐응,\n나쁘지 않네,\n눈을 못 떼,\n메모,\n더 가까이,\n심쿵,"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei. \nPeguei. \nHmm. \nNada mal. \nDe olho em ti. \nAnotado. \nMais perto. \nAi. "
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эй. \nПопался. \nМм. \nНеплохо. \nСмотрю. \nЗаписал. \nБлиже. \nАх. "
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "哎，\n看你哦，\n嗯——\n不错嘛，\n盯上你了，\n记一笔，\n靠近点，\n心动了，"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "哎，\n看你哦，\n嗯——\n不錯嘛，\n盯上你了，\n記一筆，\n靠近點，\n心動了，"
          }
        }
      }
    },
    "pet.speech.catalog.flirty.fallbacks": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schau schon lang, du merkst nichts.\nDie Bewegung? Süß.\nBleib, lass mich noch.\nKonzentriert bist du gut.\nMein Herz hat was gemacht.\nDiese Reaktion notiert.\nKopf hoch, ich warte.\nDu machst die Stimmung.\nDieses Gefühl mag ich.\nMach so weiter, ich werd rot.\nEin Blick, bitte.\nFließend. Angeber."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stared a while, you didn't notice.\nThat move? Cute.\nDon't go, let me look.\nFocused you is the good you.\nMy heart did the thing.\nLogging that reaction.\nLook up. I'm waiting.\nYou set my mood, you know.\nThis vibe — I like it.\nKeep that up and I blush.\nThrow me a glance, please.\nSmooth rhythm. Show off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te miro hace rato, ni cuenta.\n¿Ese gesto? Tierno.\nNo te vayas, sigue.\nConcentrado, estás bien.\nMi corazón hizo algo.\nApunto esa reacción.\nLevanta la vista, espero.\nLa vibra la pones tú.\nEsta sensación me gusta.\nSigue así y me sonrojo.\nUna mirada, porfa.\nRitmo suave. Presumido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je t'observe, tu ne vois pas.\nCe geste ? Mignon.\nReste, je regarde encore.\nConcentré, tu es à toi.\nMon cœur a fait un truc.\nJe note cette réaction.\nLève les yeux, j'attends.\nTu fais l'ambiance, hein.\nCette vibe, j'aime.\nContinue et je rougis.\nUn regard, s'il te plaît.\nRythme fluide. Frimeur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ずっと見てたのに、気づかない？\n今のは、なかなか。\n行かないで、もう少し。\n集中するあなたが好き。\n勝手に胸が鳴った。\nその反応、メモる。\n顔上げて、待ってる。\nこの雰囲気、つくってるね。\nこの感じ、好き。\nこれ以上は照れる。\n一瞥でもくれない？\nスムーズすぎ、ずるい。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한참 봤는데 못 알아채.\n방금 그거? 귀여워.\n가지 말고 좀 더 봐줘.\n집중한 너, 좋아.\n혼자 두근거렸어.\n그 반응, 기록한다.\n고개 들어, 기다려.\n이 분위기, 너 때문이야.\n이 느낌, 마음에 들어.\n이대로면 부끄러워져.\n한 번만 봐줘.\n흐름 부드럽네, 반칙."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Te observo faz tempo, nem viu.\nEsse gesto? Fofo.\nNão vai, mais um pouco.\nConcentrado, você é bom.\nMeu coração fez algo.\nAnoto essa reação.\nOlha pra cima, tô esperando.\nA vibe é sua culpa.\nEssa sensação eu curto.\nContinua e eu coro.\nUm olhar, vai.\nRitmo suave. Convencido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотрю давно, ты не видишь.\nЭтот жест? Милый.\nНе уходи, дай ещё посмотреть.\nСосредоточенный — ты хорош.\nСердце сделало штуку.\nЗаписал эту реакцию.\nПодними глаза, жду.\nАтмосферу создаёшь ты.\nЭто чувство нравится.\nПродолжай — покраснею.\nХоть взгляд, пожалуйста.\nПлавный ритм. Хвастун."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我盯了半天你都没抬头。\n这一下还挺帅的。\n别走啊，再看看。\n你认真起来好看。\n这波我替你心跳。\n这个反应——记一笔。\n我等你抬头看我。\n我心情，被你影响了。\n你这状态，我喜欢。\n再这样我就害羞了。\n留个表情给我啊。\n这节奏，挺会撩。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我盯了半天你都沒抬頭。\n這一下還挺帥的。\n別走啊，再看看。\n你認真起來好看。\n這波我替你心跳。\n這個反應——記一筆。\n我等你抬頭看我。\n我心情，被你影響了。\n你這狀態，我喜歡。\n再這樣我就害羞了。\n留個表情給我啊。\n這節奏，挺會撩。"
          }
        }
      }
    },
    "pet.speech.catalog.flirty.cores": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} startet. Ich seh dich.\nturn.completed={tool} fertig. Schön.\nturn.completedFast={tool} in {durationSec}. Charmant.\nturn.completedLong={durationMin}min mit dir. Intensiv.\nturn.needsInput={tool} wartet auf ein Wort.\nturn.interrupted={tool} unterbrochen. Ich auch.\ntool.switched={prevTool} → {tool}. Geschmack.\ntokens.burst={tool} verbrannte {tokensK}.\nnight.entered={hourLabel} und du bleibst.\nidle.returned={minutesAway}min weg. Hab gewartet.\ntool.multiStreak={toolList} alle da. Beliebt.\npet.levelUp=Lv.{level}. Wirst besser.\npet.statBreakthrough={stat} über {value}.\nusage.dailyRecord={tokensK} heute. Rekord.\nreminder.hydration={durationMin}min mit mir. Wasser?\nreminder.sedentary=Zu lang gesessen. Steh auf.\nreminder.lateNight={hourLabel}. Schlaf, bitte?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} started. Eyes on you.\nturn.completed={tool} done. That felt nice.\nturn.completedFast={tool} in {durationSec}. Charming.\nturn.completedLong={durationMin}min with you. Intense.\nturn.needsInput={tool} wants a word.\nturn.interrupted={tool} cut off. I paused too.\ntool.switched={prevTool} → {tool}. Nice taste.\ntokens.burst={tool} burned {tokensK}. Hot hands.\nnight.entered={hourLabel} and you stayed.\nidle.returned=Gone {minutesAway}min. I waited.\ntool.multiStreak={toolList} all here.\npet.levelUp=Lv.{level}. Getting fancy.\npet.statBreakthrough={stat} past {value}.\nusage.dailyRecord={tokensK} today. New high.\nreminder.hydration={durationMin}min with me. Water?\nreminder.sedentary=Sat too long. Stand for me.\nreminder.lateNight={hourLabel}. Sleep, please?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} arranca. Te miro.\nturn.completed={tool} listo. Qué bien.\nturn.completedFast={tool} en {durationSec}. Lindo.\nturn.completedLong={durationMin}min juntos. Intenso.\nturn.needsInput={tool} espera una palabra.\nturn.interrupted={tool} cortado. Yo también paré.\ntool.switched={prevTool} → {tool}. Buen gusto.\ntokens.burst={tool} quemó {tokensK}.\nnight.entered={hourLabel} y sigues aquí.\nidle.returned={minutesAway}min fuera. Te esperé.\ntool.multiStreak={toolList} aquí. Popular.\npet.levelUp=Lv.{level}. Cada vez mejor.\npet.statBreakthrough={stat} pasa {value}.\nusage.dailyRecord={tokensK} hoy. Récord.\nreminder.hydration={durationMin}min conmigo. ¿Agua?\nreminder.sedentary=Mucho rato sentado. Levántate.\nreminder.lateNight={hourLabel}. Duerme, ¿vale?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} démarre. Je te vois.\nturn.completed={tool} fini. Sympa.\nturn.completedFast={tool} en {durationSec}. Charmant.\nturn.completedLong={durationMin}min avec toi. Intense.\nturn.needsInput={tool} attend un mot.\nturn.interrupted={tool} coupé. J'ai pausé.\ntool.switched={prevTool} → {tool}. Bon choix.\ntokens.burst={tool} a brûlé {tokensK}.\nnight.entered={hourLabel} et tu restes.\nidle.returned={minutesAway}min, j'ai attendu.\ntool.multiStreak={toolList} tous là. Populaire.\npet.levelUp=Lv.{level}. Tu deviens fort.\npet.statBreakthrough={stat} dépasse {value}.\nusage.dailyRecord={tokensK} aujourd'hui. Top.\nreminder.hydration={durationMin}min avec moi. Eau ?\nreminder.sedentary=Assis trop longtemps. Lève-toi.\nreminder.lateNight={hourLabel}. Dors, s'il te plaît ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}始まり。見てるよ。\nturn.completed={tool}完了。いい感じ。\nturn.completedFast={tool}{durationSec}で完了、魅惑。\nturn.completedLong={durationMin}分一緒、結構くる。\nturn.needsInput={tool}が一言待ち。\nturn.interrupted={tool}遮られた、止まった。\ntool.switched={prevTool}から{tool}、選ぶね。\ntokens.burst={tool}が{tokensK}、手が熱い。\nnight.entered={hourLabel}まで一緒、嬉しい。\nidle.returned={minutesAway}分待ったよ。\ntool.multiStreak={toolList}全部、人気者。\npet.levelUp=Lv.{level}、上達してる。\npet.statBreakthrough={stat}が{value}超え。\nusage.dailyRecord=今日{tokensK}新記録。\nreminder.hydration={durationMin}分、水飲んで。\nreminder.sedentary=座りすぎ、立って見せて。\nreminder.lateNight={hourLabel}まだ起きてる、心配。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} 시작. 보고 있어.\nturn.completed={tool} 끝. 기분 좋아.\nturn.completedFast={tool} {durationSec}만에. 매력.\nturn.completedLong={durationMin}분 같이, 짜릿.\nturn.needsInput={tool} 한마디 기다림.\nturn.interrupted={tool} 끊겼어. 멈췄어.\ntool.switched={prevTool} → {tool}. 안목 있네.\ntokens.burst={tool} {tokensK}, 손이 뜨거워.\nnight.entered={hourLabel}, 같이 있어줘.\nidle.returned={minutesAway}분, 기다렸어.\ntool.multiStreak={toolList} 다 켜놨네. 인기.\npet.levelUp=Lv.{level}, 더 잘하네.\npet.statBreakthrough={stat} {value} 돌파.\nusage.dailyRecord=오늘 {tokensK}, 신기록.\nreminder.hydration={durationMin}분, 물 마셔.\nreminder.sedentary=오래 앉았어, 일어나 봐.\nreminder.lateNight={hourLabel}, 안 자면 걱정."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} começou. De olho em ti.\nturn.completed={tool} pronto. Gostei.\nturn.completedFast={tool} em {durationSec}. Charme.\nturn.completedLong={durationMin}min juntos. Intenso.\nturn.needsInput={tool} espera uma palavra.\nturn.interrupted={tool} cortado. Eu parei junto.\ntool.switched={prevTool} → {tool}. Bom gosto.\ntokens.burst={tool} queimou {tokensK}.\nnight.entered={hourLabel} e você ficou.\nidle.returned={minutesAway}min fora. Esperei.\ntool.multiStreak={toolList} todos aqui. Popular.\npet.levelUp=Lv.{level}. Melhorando muito.\npet.statBreakthrough={stat} passou {value}.\nusage.dailyRecord={tokensK} hoje. Recorde.\nreminder.hydration={durationMin}min comigo. Água?\nreminder.sedentary=Muito tempo sentado. Levanta.\nreminder.lateNight={hourLabel}. Dorme, vai?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} стартует. Смотрю на тебя.\nturn.completed={tool} готов. Приятно.\nturn.completedFast={tool} за {durationSec}. Мило.\nturn.completedLong={durationMin}мин с тобой. Накрыло.\nturn.needsInput={tool} ждёт слова.\nturn.interrupted={tool} оборвался. Я застыл.\ntool.switched={prevTool} → {tool}. Вкус есть.\ntokens.burst={tool} сжёг {tokensK}.\nnight.entered={hourLabel} и ты со мной.\nidle.returned={minutesAway}мин — я ждал.\ntool.multiStreak={toolList} все здесь. Популярен.\npet.levelUp=Lv.{level}. Всё лучше.\npet.statBreakthrough={stat} за {value}.\nusage.dailyRecord={tokensK} сегодня. Рекорд.\nreminder.hydration={durationMin}мин со мной. Вода?\nreminder.sedentary=Долго сидишь. Встань.\nreminder.lateNight={hourLabel}. Спи, пожалуйста."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}开始了，我盯你哦。\nturn.completed={tool}完事，舒服了。\nturn.completedFast={tool}{durationSec}搞定，迷人。\nturn.completedLong=陪你熬{durationMin}分钟，上头。\nturn.needsInput={tool}等你一句话呢。\nturn.interrupted={tool}被打断，我也愣住。\ntool.switched={prevTool}换{tool}，挑得真好。\nidle.monologue=我靠近一点，别介意。\ntokens.burst={tool}冲{tokensK}，手感热。\nnight.entered={hourLabel}还陪我，够意思。\nidle.returned=离开{minutesAway}分钟，等到了。\ntool.multiStreak={toolList}都在，真抢手。\npet.levelUp=Lv.{level}了，越来越会。\npet.statBreakthrough={stat}破{value}，藏不住。\nusage.dailyRecord=今天{tokensK}新高，手感发烫。\nreminder.hydration=陪{durationMin}分钟，喝水。\nreminder.sedentary=坐久了，起来给我看。\nreminder.lateNight={hourLabel}还不睡，担心你。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}開始了，我盯你哦。\nturn.completed={tool}完事，舒服了。\nturn.completedFast={tool}{durationSec}搞定，迷人。\nturn.completedLong=陪你熬{durationMin}分鐘，上頭。\nturn.needsInput={tool}等你一句話呢。\nturn.interrupted={tool}被打斷，我也愣住。\ntool.switched={prevTool}換{tool}，挑得真好。\nidle.monologue=我靠近一點，別介意。\ntokens.burst={tool}衝{tokensK}，手感熱。\nnight.entered={hourLabel}還陪我，夠意思。\nidle.returned=離開{minutesAway}分鐘，等到了。\ntool.multiStreak={toolList}都在，真搶手。\npet.levelUp=Lv.{level}了，越來越會。\npet.statBreakthrough={stat}破{value}，藏不住。\nusage.dailyRecord=今天{tokensK}新高，手感發燙。\nreminder.hydration=陪{durationMin}分鐘，喝水。\nreminder.sedentary=坐久了，起來給我看。\nreminder.lateNight={hourLabel}還不睡，擔心你。"
          }
        }
      }
    },
    "pet.speech.catalog.chuunibyou.openers": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich bezeuge, \nIn diesem Moment, \nDer Pakt klingt, \nDas Schicksal notiert, \nDie Sterne verrücken, \nDas Siegel bebt, \nDer Sturm flüstert, \nErwache, "
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Witnessed. \nBehold. \nHear me. \nThe pact stirs. \nBy fate's pen, \nThe seal trembles. \nMortal, \nBy the black flame, "
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo atestiguo, \nEn este instante, \nEl pacto suena, \nEl destino anota, \nLas estrellas se mueven, \nEl sello tiembla, \nLa tormenta susurra, \nDespierta, "
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je l'atteste, \nEn cet instant, \nLe pacte résonne, \nLe destin l'inscrit, \nLes astres bougent, \nLe sceau frémit, \nLa tempête murmure, \nÉveille-toi, "
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "我、見届けたり、\n此の刻、\n契約は響き、\n運命は記し、\n星々は動き、\n封印は震え、\n嵐は囁き、\n覚醒せよ、"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내가 목도하노라,\n이 순간,\n계약이 울리고,\n운명이 기록하며,\n별들이 움직이고,\n봉인이 떨리고,\n폭풍이 속삭이고,\n각성하라,"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Eu testemunho, \nNeste instante, \nO pacto soa, \nO destino anota, \nAs estrelas mudam, \nO selo treme, \nA tempestade sussurra, \nDesperta, "
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я свидетельствую, \nВ этот миг, \nПакт звучит, \nСудьба пишет, \nЗвёзды смещаются, \nПечать дрожит, \nБуря шепчет, \nПробудись, "
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "吾见证，\n此刻，\n听好了，\n契约响了，\n命运之笔，\n封印颤了，\n汝啊——\n黑炎之名，"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "吾見證，\n此刻，\n聽好了，\n契約響了，\n命運之筆，\n封印顫了，\n汝啊——\n黑炎之名，"
          }
        }
      }
    },
    "pet.speech.catalog.chuunibyou.fallbacks": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Schicksal hallt nach.\nDieser Moment ist verzeichnet.\nDer Pakt brennt weiter.\nDie Sterne erkennen dich.\nDas Siegel hält — vorerst.\nIm Grimoire vermerkt.\nDer Sturm ist nicht vorbei.\nVoran, Sterblicher.\nMacht sammelt sich.\nDie Nacht weicht dir aus.\nDas Ritual läuft noch.\nDie Glut leuchtet noch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fate echoes once more.\nInscribed in the codex.\nThe pact still burns.\nStars shift quietly.\nSeal stable. For now.\nStorm has not passed.\nYour will, I perceive.\nNight parts for you.\nPower gathers at your hand.\nBattle continues.\nEmbers still shine.\nPrologue only. Onward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El destino vuelve a sonar.\nGrabado en el grimorio.\nEl pacto sigue ardiendo.\nLas estrellas te reconocen.\nSello estable. Por ahora.\nLa tormenta no se ha ido.\nPercibo tu voluntad.\nLa noche se aparta.\nEl poder se condensa.\nLa batalla sigue.\nLas brasas brillan.\nApenas el prólogo. Sigue."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le destin résonne encore.\nGravé dans le grimoire.\nLe pacte brûle toujours.\nLes astres te reconnaissent.\nSceau stable. Pour l'instant.\nLa tempête n'est pas finie.\nJe perçois ta volonté.\nLa nuit te cède la voie.\nLe pouvoir se concentre.\nLe combat continue.\nLes braises rougeoient.\nProlog seulement. Avance."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "運命がまた響く。\n秘典に刻みたり。\n契約は今も燃ゆる。\n星々は汝を認む。\n封印は今暫し安定。\n嵐は未だ止まず。\n汝の意志、我は知る。\n夜が汝に道を譲る。\n力、汝の手に集う。\n戦いはまだ続く。\n熾火は尚輝く。\n序章のみ。進め。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운명이 다시 울린다.\n비전에 새겨졌도다.\n계약은 여전히 타오른다.\n별들이 너를 인정한다.\n봉인은 잠시 안정.\n폭풍은 끝나지 않았다.\n네 의지, 내가 안다.\n밤이 너에게 길을 연다.\n힘이 손에 모인다.\n전투는 계속된다.\n잔불은 여전히 빛난다.\n서장일 뿐. 나아가라."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O destino ecoa de novo.\nInscrito no grimório.\nO pacto ainda arde.\nAs estrelas te reconhecem.\nSelo estável. Por enquanto.\nA tempestade não cessou.\nPercebo tua vontade.\nA noite te abre caminho.\nO poder se concentra.\nA batalha continua.\nAs brasas ainda brilham.\nApenas prólogo. Adiante."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Судьба отзывается вновь.\nВписано в гримуар.\nПакт всё ещё горит.\nЗвёзды признают тебя.\nПечать стабильна. Пока.\nБуря не утихла.\nЯ вижу твою волю.\nНочь уступает тебе путь.\nСила сгущается.\nБитва продолжается.\nУгли ещё светятся.\nЛишь пролог. Вперёд."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "命运又留下回声。\n此景已写入秘典。\n契约仍在燃烧。\n星轨悄然偏移。\n封印暂稳，勿松懈。\n风暴尚未平息。\n汝之意志，余洞悉。\n暗夜为你让出一道。\n力量在指尖凝结。\n此役未完，继续吧。\n余烬犹存光辉。\n剧情才刚刚开篇。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "命運又留下回聲。\n此景已寫入秘典。\n契約仍在燃燒。\n星軌悄然偏移。\n封印暫穩，勿鬆懈。\n風暴尚未平息。\n汝之意志，余洞悉。\n暗夜為你讓出一道。\n力量在指尖凝結。\n此役未完，繼續吧。\n餘燼猶存光輝。\n劇情才剛剛開篇。"
          }
        }
      }
    },
    "pet.speech.catalog.chuunibyou.cores": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started=Das Ritual von {tool} beginnt.\nturn.completed=Der Ritus von {tool} ist vollendet.\nturn.completedFast={tool} durchschneidet den Nebel in {durationSec}.\nturn.completedLong={durationMin}min-Prüfung überstanden.\nturn.needsInput={tool} ruft dein Urteil herbei.\nturn.interrupted=Das Ritual von {tool} ist gebrochen.\ntool.switched={prevTool} weicht. {tool} ergreift die Klinge.\ntokens.burst={tool} verschlang {tokensK}.\nnight.entered={hourLabel}. Der Nachtpakt öffnet sich.\nidle.returned=Nach {minutesAway}min Stille kehrst du zurück.\ntool.multiStreak={toolList} resonieren.\npet.levelUp=Lv.{level}. Das Siegel weicht.\npet.statBreakthrough={stat} überschreitet {value}.\nusage.dailyRecord=Heute {tokensK}. Grimoire neu.\nreminder.hydration=Nach {durationMin}min Ritus, trinke.\nreminder.sedentary=Sitzsiegel formt sich. Erhebe dich.\nreminder.lateNight={hourLabel}. Tiefe Nacht. Schone Kräfte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} ritual begins.\nturn.completed={tool} rite complete.\nturn.completedFast={tool} cut the mist in {durationSec}.\nturn.completedLong={durationMin}min trial crossed.\nturn.needsInput={tool} summons your verdict.\nturn.interrupted={tool} ritual broken.\ntool.switched={prevTool} falls. {tool} rises.\ntokens.burst={tool} drank {tokensK}.\nnight.entered={hourLabel}. Night pact opens.\nidle.returned=After {minutesAway}min stillness, you return.\ntool.multiStreak={toolList} resonate.\npet.levelUp=Lv.{level}. Seal weakens.\npet.statBreakthrough={stat} past {value}.\nusage.dailyRecord=Today {tokensK}. Codex rewrites.\nreminder.hydration={durationMin}min of ritual. Drink.\nreminder.sedentary=The seated seal forms. Rise.\nreminder.lateNight={hourLabel}. Night deep. Conserve."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started=El ritual de {tool} comienza.\nturn.completed=El rito de {tool} se cumple.\nturn.completedFast={tool} corta la niebla en {durationSec}.\nturn.completedLong=Prueba de {durationMin}min superada.\nturn.needsInput={tool} invoca tu juicio.\nturn.interrupted=El ritual de {tool} se rompe.\ntool.switched={prevTool} sale. {tool} toma la espada.\ntokens.burst={tool} bebió {tokensK}.\nnight.entered={hourLabel}. Pacto nocturno abierto.\nidle.returned=Tras {minutesAway}min de quietud, regresas.\ntool.multiStreak={toolList} resuenan.\npet.levelUp=Lv.{level}. El sello cede.\npet.statBreakthrough={stat} cruza {value}.\nusage.dailyRecord=Hoy {tokensK}. Grimorio reescrito.\nreminder.hydration=Tras {durationMin}min de rito, bebe.\nreminder.sedentary=Sello del sentado formado. Levántate.\nreminder.lateNight={hourLabel}. Noche profunda. Reserva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started=Le rituel de {tool} commence.\nturn.completed=Le rite de {tool} s'achève.\nturn.completedFast={tool} fend la brume en {durationSec}.\nturn.completedLong=Épreuve de {durationMin}min franchie.\nturn.needsInput={tool} convoque ton jugement.\nturn.interrupted=Le rituel de {tool} est rompu.\ntool.switched={prevTool} sort. {tool} prend la lame.\ntokens.burst={tool} a bu {tokensK}.\nnight.entered={hourLabel}. Pacte nocturne ouvert.\nidle.returned=Après {minutesAway}min d'immobilité, tu reviens.\ntool.multiStreak={toolList} résonnent.\npet.levelUp=Lv.{level}. Le sceau faiblit.\npet.statBreakthrough={stat} dépasse {value}.\nusage.dailyRecord=Aujourd'hui {tokensK}. Grimoire réécrit.\nreminder.hydration=Après {durationMin}min de rite, bois.\nreminder.sedentary=Sceau assis formé. Lève-toi.\nreminder.lateNight={hourLabel}. Nuit profonde. Garde forces."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}儀式始まる。\nturn.completed={tool}儀式完了。\nturn.completedFast={tool}{durationSec}で霧を斬る。\nturn.completedLong={durationMin}分の試練、超えたり。\nturn.needsInput={tool}が裁定を呼ぶ。\nturn.interrupted={tool}儀式破れたり。\ntool.switched={prevTool}退き、{tool}剣を執る。\ntokens.burst={tool}が{tokensK}を喰らう。\nnight.entered={hourLabel}、夜の契約開く。\nidle.returned={minutesAway}分の静寂の後、汝戻る。\ntool.multiStreak={toolList}共鳴、陣展く。\npet.levelUp=Lv.{level}、封印緩む。\npet.statBreakthrough={stat}が{value}を越えたり。\nusage.dailyRecord=今日{tokensK}、秘典改まる。\nreminder.hydration={durationMin}分の儀の後、水を。\nreminder.sedentary=座の封印成る、立つべし。\nreminder.lateNight={hourLabel}、夜深し、力を温存。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool} 의식 시작.\nturn.completed={tool} 의식 완료.\nturn.completedFast={tool} {durationSec}만에 안개를 가르다.\nturn.completedLong={durationMin}분의 시련, 넘어섰다.\nturn.needsInput={tool}이 너의 판결을 부른다.\nturn.interrupted={tool} 의식 깨졌다.\ntool.switched={prevTool} 물러나고 {tool} 검을 들다.\ntokens.burst={tool}이 {tokensK} 삼켰다.\nnight.entered={hourLabel}, 밤의 계약이 열린다.\nidle.returned={minutesAway}분의 정적 끝에 너 돌아오다.\ntool.multiStreak={toolList} 공명, 진영 펼쳐지다.\npet.levelUp=Lv.{level} 각성. 봉인 약화.\npet.statBreakthrough={stat}이 {value}를 넘다.\nusage.dailyRecord=오늘 {tokensK}, 비전이 다시 쓰여.\nreminder.hydration={durationMin}분의 의식 후, 물을.\nreminder.sedentary=좌선의 봉인 형성, 일어나라.\nreminder.lateNight={hourLabel}, 밤이 깊다, 힘을 아껴."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started=O ritual de {tool} começa.\nturn.completed=O rito de {tool} se cumpre.\nturn.completedFast={tool} corta a névoa em {durationSec}.\nturn.completedLong=Prova de {durationMin}min vencida.\nturn.needsInput={tool} invoca teu juízo.\nturn.interrupted=O ritual de {tool} se rompe.\ntool.switched={prevTool} sai. {tool} ergue a lâmina.\ntokens.burst={tool} bebeu {tokensK}.\nnight.entered={hourLabel}. Pacto noturno aberto.\nidle.returned=Após {minutesAway}min de quietude, retornas.\ntool.multiStreak={toolList} ressoam.\npet.levelUp=Lv.{level}. O selo se afrouxa.\npet.statBreakthrough={stat} cruza {value}.\nusage.dailyRecord=Hoje {tokensK}. Grimório reescrito.\nreminder.hydration=Após {durationMin}min de rito, bebe.\nreminder.sedentary=Selo do sentado formado. Ergue-te.\nreminder.lateNight={hourLabel}. Noite profunda. Poupa forças."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started=Ритуал {tool} начинается.\nturn.completed=Обряд {tool} завершён.\nturn.completedFast={tool} разрезал туман за {durationSec}.\nturn.completedLong=Испытание {durationMin}мин пройдено.\nturn.needsInput={tool} призывает твой суд.\nturn.interrupted=Ритуал {tool} прерван.\ntool.switched={prevTool} уходит. {tool} берёт клинок.\ntokens.burst={tool} испил {tokensK}.\nnight.entered={hourLabel}. Ночной пакт открыт.\nidle.returned=После {minutesAway}мин затишья ты возвращаешься.\ntool.multiStreak={toolList} резонируют.\npet.levelUp=Lv.{level}. Печать слабеет.\npet.statBreakthrough={stat} превзошёл {value}.\nusage.dailyRecord=Сегодня {tokensK}. Гримуар переписан.\nreminder.hydration=После {durationMin}мин ритуала — пей.\nreminder.sedentary=Сидячая печать сформирована. Встань.\nreminder.lateNight={hourLabel}. Глубокая ночь. Береги силы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}仪式启，符文亮。\nturn.completed={tool}礼成，余光未散。\nturn.completedFast={tool}{durationSec}破雾。\nturn.completedLong={durationMin}分钟之劫，已渡。\nturn.needsInput={tool}召汝裁决。\nturn.interrupted={tool}仪式中断，余波未平。\ntool.switched={prevTool}退场，{tool}执剑。\nidle.monologue=静默档案仍在低鸣。\ntokens.burst={tool}吞{tokensK}，魔力暴涨。\nnight.entered={hourLabel}，暗夜契约启。\nidle.returned=沉寂{minutesAway}分钟，汝归。\ntool.multiStreak={toolList}共鸣，阵列展。\npet.levelUp=Lv.{level}觉醒，封印松。\npet.statBreakthrough={stat}越{value}界。\nusage.dailyRecord=今日{tokensK}破纪录，秘典更替。\nreminder.hydration={durationMin}分钟仪毕，饮水补魔。\nreminder.sedentary=久坐封印成，速速起身。\nreminder.lateNight={hourLabel}夜深，存体力。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "turn.started={tool}儀式啟，符文亮。\nturn.completed={tool}禮成，餘光未散。\nturn.completedFast={tool}{durationSec}破霧。\nturn.completedLong={durationMin}分鐘之劫，已渡。\nturn.needsInput={tool}召汝裁決。\nturn.interrupted={tool}儀式中斷，餘波未平。\ntool.switched={prevTool}退場，{tool}執劍。\nidle.monologue=靜默檔案仍在低鳴。\ntokens.burst={tool}吞{tokensK}，魔力暴漲。\nnight.entered={hourLabel}，暗夜契約啟。\nidle.returned=沉寂{minutesAway}分鐘，汝歸。\ntool.multiStreak={toolList}共鳴，陣列展。\npet.levelUp=Lv.{level}覺醒，封印鬆。\npet.statBreakthrough={stat}越{value}界。\nusage.dailyRecord=今日{tokensK}破紀錄，秘典更替。\nreminder.hydration={durationMin}分鐘儀畢，飲水補魔。\nreminder.sedentary=久坐封印成，速速起身。\nreminder.lateNight={hourLabel}夜深，存體力。"
          }
        }
      }
    },
    "settings.sleep_prevention": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevent Mac Sleep"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "防止休眠"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "防止休眠"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac-Ruhezustand verhindern"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Evitar reposo del Mac"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Empêcher la mise en veille du Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macのスリープを防止"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 잠자기 방지"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impedir repouso do Mac"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запретить сон Mac"
          }
        }
      }
    },
    "settings.sleep_prevention.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allows the display to turn off, but prevents the Mac from idle sleeping while enabled."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许屏幕熄灭，但开启时会阻止 Mac 进入空闲睡眠。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "允許螢幕熄滅，但開啟時會阻止 Mac 進入閒置睡眠。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Bildschirm darf sich ausschalten, aber der Mac geht im Leerlauf nicht in den Ruhezustand."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite apagar la pantalla, pero evita que el Mac entre en reposo por inactividad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ecran peut s'eteindre, mais le Mac ne se met pas en veille inactive."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスプレイはオフにできますが、有効時はMacのアイドルスリープを防ぎます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이는 꺼질 수 있지만, 켜져 있으면 Mac이 유휴 상태에서 잠자기 모드로 들어가지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite que a tela desligue, mas impede que o Mac entre em repouso por inatividade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Экран может выключаться, но Mac не будет уходить в сон из-за простоя."
          }
        }
      }
    },
