    "settings.ai.provider.local_llama_help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs llama.cpp locally for memory extraction and pet line polishing. The model catalog refreshes from GitHub, and model downloads prefer ModelScope in China."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Führt llama.cpp lokal für Speicherextraktion und Haustier-Textverfeinerung aus. Der Modellkatalog wird von GitHub aktualisiert; in China werden Downloads bevorzugt über ModelScope geladen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta llama.cpp localmente para extraer memoria y pulir frases de la mascota. El catálogo de modelos se actualiza desde GitHub y en China se prioriza ModelScope para descargas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exécute llama.cpp localement pour l’extraction de mémoire et la retouche des répliques du compagnon. Le catalogue se met à jour depuis GitHub et les téléchargements privilégient ModelScope en Chine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶抽出とペットの台詞調整に llama.cpp をローカルで使用します。モデル一覧は GitHub から更新され、中国では ModelScope のダウンロード経路を優先します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리 추출과 펫 대사 다듬기에 llama.cpp를 로컬로 사용합니다. 모델 목록은 GitHub에서 새로 고치며, 중국에서는 ModelScope 다운로드 경로를 우선합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Executa llama.cpp localmente para extração de memória e polimento das falas do pet. O catálogo de modelos é atualizado pelo GitHub e, na China, os downloads priorizam o ModelScope."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локально запускает llama.cpp для извлечения памяти и доработки реплик питомца. Каталог моделей обновляется с GitHub, а в Китае загрузки предпочитают ModelScope."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用本机 llama.cpp 做记忆提取和宠物台词润色。模型列表会从 GitHub 刷新，国内下载优先使用 ModelScope。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用本機 llama.cpp 做記憶擷取和寵物台詞潤飾。模型列表會從 GitHub 重新整理，國內下載優先使用 ModelScope。"
          }
        }
      }
    },
