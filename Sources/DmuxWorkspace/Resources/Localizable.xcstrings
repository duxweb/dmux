    "memory.status.provider_configuration_needed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory needs an enabled AI channel. In Settings > AI, enable a provider and turn on Use For Memory Extraction."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记忆需要可用的 AI 渠道。请在设置 > AI 启用渠道，并打开“用于记忆提取”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶需要可用的 AI 渠道。請在設定 > AI 啟用渠道，並開啟「用於記憶擷取」。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Speicher braucht einen aktivierten AI-Kanal. Aktiviere unter Einstellungen > AI einen Anbieter und schalte „Für Speicherextraktion verwenden“ ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La memoria necesita un canal de AI habilitado. En Ajustes > AI, activa un proveedor y enciende “Usar para extracción de memoria”."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La mémoire nécessite un canal AI activé. Dans Réglages > AI, activez un fournisseur et l’option « Utiliser pour l’extraction de mémoire »."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリには有効な AI チャネルが必要です。設定 > AI でプロバイダーを有効にし、「メモリ抽出に使用」をオンにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리에는 활성화된 AI 채널이 필요합니다. 설정 > AI에서 공급자를 켜고 “메모리 추출에 사용”을 켜세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A memória precisa de um canal de AI ativado. Em Ajustes > AI, ative um provedor e marque “Usar para extração de memória”."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Памяти нужен включенный AI-канал. В Настройки > AI включите провайдера и параметр «Использовать для извлечения памяти»."
          }
        }
      }
    },
