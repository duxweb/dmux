    "settings.notifications.channel.slack.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deliver notifications to a Slack incoming webhook. Optional auth token is only needed for custom gateways."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送通知到 Slack Incoming Webhook；仅在自定义网关需要鉴权时填写可选 Token。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發送通知到 Slack Incoming Webhook；僅在自訂閘道需要驗證時填寫可選 Token。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Benachrichtigungen an einen eingehenden Slack-Webhook. Ein optionales Auth-Token wird nur für benutzerdefinierte Gateways benötigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía notificaciones a un webhook entrante de Slack. El token de autenticación opcional solo se necesita para pasarelas personalizadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des notifications vers un webhook entrant Slack. Un jeton d'authentification facultatif n'est requis que pour des passerelles personnalisées."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Slack Incoming Webhook に通知を送信します。オプションの認証トークンはカスタムゲートウェイでのみ必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Slack Incoming Webhook으로 알림을 보냅니다. 선택적 인증 토큰은 사용자 지정 게이트웨이에서만 필요합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia notificações para um webhook de entrada do Slack. O token opcional de autenticação só é necessário para gateways personalizados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет уведомления во входящий webhook Slack. Необязательный токен авторизации нужен только для пользовательских шлюзов."
          }
        }
      }
    },
