    "project.remove.confirm_format": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to remove project %@? Files on disk will not be deleted."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要移除项目“%@”吗？磁盘上的文件不会被删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要移除項目「%@」嗎？磁碟上的檔案不會被刪除。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie das Projekt %@ wirklich entfernen? Dateien auf der Festplatte werden nicht gelöscht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar el proyecto %@? Los archivos del disco no se borrarán."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer le projet %@ ? Les fichiers sur le disque ne seront pas supprimés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロジェクト %@ を削除しますか？ディスク上のファイルは削除されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로젝트 %@를 제거할까요? 디스크의 파일은 삭제되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja remover o projeto %@? Os arquivos no disco não serão apagados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить проект %@? Файлы на диске не будут удалены."
          }
        }
      }
    },
