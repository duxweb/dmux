    "settings.notifications.channel.dingtalk.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Post messages with a DingTalk robot webhook. You can fill either the full URL or the access token."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用钉钉机器人 Webhook 发送消息，可填写完整 Webhook 地址或 Access Token。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用釘釘機器人 Webhook 發送訊息，可填寫完整 Webhook 位址或 Access Token。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Nachrichten über einen DingTalk-Roboter-Webhook. Sie können die vollständige URL oder das Zugriffstoken eintragen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía mensajes con un webhook de robot de DingTalk. Puedes completar la URL completa o el access token."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie des messages avec un webhook de robot DingTalk. Vous pouvez renseigner l'URL complète ou le jeton d'accès."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DingTalk ロボットの Webhook でメッセージを送信します。完全な URL または Access Token を入力できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DingTalk 로봇 Webhook으로 메시지를 보냅니다. 전체 URL 또는 Access Token을 입력할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia mensagens com um webhook de robô do DingTalk. Você pode informar a URL completa ou o token de acesso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет сообщения через webhook-робота DingTalk. Можно указать полный URL или токен доступа."
          }
        }
      }
    },
